# Toonflow-Backend 生产环境配置模板
# 用法：cp .env.production.example .env 然后按下方说明填写
# 注意：.env 已加入 .gitignore，不会被提交

# ===== PostgreSQL（compose 内置，走 docker 内部网络）=====
# PG_HOST 必须填 compose 服务名 postgres，不要改
PG_HOST=postgres
PG_PORT=5432
PG_USER=toonflow
# 【必改】数据库密码，生成：openssl rand -hex 16
PG_PASSWORD=CHANGE_ME_db_password
PG_DATABASE=toonflow

# ===== HTTP =====
PORT=4000

# ===== JWT =====
# 【必改】登录 token 签名密钥，生成：openssl rand -hex 32
# 重要：此值必须与「客户端构建时注入的 JWT_SECRET」完全一致，否则登录态无法互通
JWT_SECRET=CHANGE_ME_jwt_secret_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ===== 火山引擎 TOS（媒体上传需要真实凭据；只验证登录/数据流程可留空）=====
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_REGION=cn-shanghai
TOS_BUCKET=toonflow-service
