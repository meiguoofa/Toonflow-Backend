{
  "atlascloud": {
    "id": "atlascloud",
    "name": "AtlasCloud MASS",
    "description": "AtlasCloud 全模态平台接入 Toonflow。默认按官方文档填写文本、图片、视频与任务轮询路径。",
    "author": "AtlasCloud",
    "version": "1.0",
    "icon": "",
    "inputs": [
      {
        "key": "apiKey",
        "label": "API密钥",
        "type": "password",
        "required": true,
        "placeholder": "AtlasCloud API Key"
      },
      {
        "key": "chatBaseUrl",
        "label": "文本基地址",
        "type": "url",
        "required": true,
        "placeholder": "https://api.atlascloud.ai/v1",
        "disabled": true
      },
      {
        "key": "mediaBaseUrl",
        "label": "媒体基地址",
        "type": "url",
        "required": true,
        "placeholder": "https://api.atlascloud.ai/api/v1",
        "disabled": true
      }
    ],
    "defaultInputValues": {
      "apiKey": "",
      "chatBaseUrl": "https://api.atlascloud.ai/v1",
      "mediaBaseUrl": "https://api.atlascloud.ai/api/v1"
    },
    "template": "atlascloud",
    "protocol": "openai-compatible"
  },
