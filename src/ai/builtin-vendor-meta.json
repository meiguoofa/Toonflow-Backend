      {
        "key": "apiKey",
        "label": "API密钥",
        "type": "password",
        "required": true
      }
    ],
    "defaultInputValues": {
      "apiKey": "",
      "baseUrl": "https://api.toonflow.net/v1"
    },
    "template": "toonflow",
    "protocol": "openai-compatible"
